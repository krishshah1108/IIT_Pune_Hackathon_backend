APP_NAME=MediReminder Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
# Raw v0 + Gemini assistant text in logs, max chars (0 = log only character counts, not body)
LLM_RESPONSE_LOG_MAX_CHARS=8000

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=medireminder

OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_REQUESTS_PER_HOUR=10

JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=10080

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rushabh11.dev@gmail.com
SMTP_PASS=your-password
EMAIL_FROM=no-reply@medireminder.ai
SMTP_TIMEOUT_SECONDS=20
SMTP_STARTTLS=true

# V0 vision is deprecated in this setup (Gemini is used for vision/literacy/food).
# V0_API_BASE_URL=https://api.v0.dev
# V0_API_KEY=
# V0_MODEL=auto
# V0_TIMEOUT_SECONDS=300

# Google Gemini (vision + literacy + food)
GOOGLE_API_KEY=your-google-api-key
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_LITERACY_MODEL=gemini-2.5-flash
GEMINI_FOOD_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=90
GEMINI_TEMPERATURE=0.35
GEMINI_MAX_OUTPUT_TOKENS=2048

CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=medi_reminder
MAX_PRESCRIPTION_UPLOAD_BYTES=15728640

SCHEDULE_SCAN_INTERVAL_SECONDS=60
MISSED_DOSE_GRACE_MINUTES=30
